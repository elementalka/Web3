# Combined Vercel showcase (default profile; TEST FUNDS ONLY)
DEPLOYMENT_PROFILE=showcase
APP_ENV=staging
DEMO_AUTH_ENABLED=true
SHOWCASE_DATA_FILE=/tmp/web3-casino-showcase.json
# Required on Vercel: generate with `node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"`
SHOWCASE_SESSION_SECRET=
# Recommended for a fully playable multi-instance Vercel demo. The Upstash
# Marketplace integration injects these automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional override. By default the key is isolated by Vercel project + environment.
SHOWCASE_REDIS_KEY=

# Same-origin combined deployment: leave blank. For a separately hosted API,
# set the full HTTPS origin before the Vite build, without a trailing slash.
VITE_API_URL=
WEB_ORIGIN=

# Telegram Mini App integration (optional for the browser showcase)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Production-only contract. Supplying these values does NOT make the current
# repository production-ready; DEPLOYMENT_PROFILE=production remains fail-closed
# until durable adapters and audits described in docs/DEPLOYMENT.md exist.
DATABASE_URL=
EVM_RPC_URL=
EVM_CHAIN_ID=
USDC_CONTRACT_ADDRESS=
TREASURY_SIGNER_SECRET=
KYC_PROVIDER_API_KEY=
