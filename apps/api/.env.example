APP_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
DEMO_AUTH_ENABLED=true
STORE_MODE=file
SANDBOX_TOOLS_ENABLED=true
MOCK_PAYMENTS_ENABLED=true
# Required only for the stateless multi-instance Vercel showcase adapter.
SHOWCASE_SESSION_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Current Vercel Marketplace naming (alternative to UPSTASH_REDIS_REST_*).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional override. The default namespace includes project + environment.
SHOWCASE_REDIS_KEY=

# Showcase-only second factor. Production must use a real TOTP/WebAuthn flow.
ADMIN_2FA_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Local test data only. The API defaults to apps/api/.data/dev-db.json.
